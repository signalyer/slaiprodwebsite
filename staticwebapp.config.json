{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  },
  "globalHeaders": {
    "Cache-Control": "no-store, no-cache, must-revalidate",
    "X-Robots-Tag": "noindex, nofollow, noarchive, nosnippet",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Permissions-Policy": "geolocation=(), camera=(), microphone=()"
  },
  "routes": [
    { "route": "/admin", "rewrite": "/api/admin" },
    { "route": "/admin/login", "rewrite": "/api/admin/login" },
    { "route": "/admin/logout", "rewrite": "/api/admin/logout" }
  ]
}
